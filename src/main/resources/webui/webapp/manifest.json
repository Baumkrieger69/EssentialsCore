{
    "name": "EssentialsCore WebUI",
    "short_name": "EssentialsCore",
    "description": "Advanced WebUI and Remote Management System for EssentialsCore",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#1a1d23",
    "theme_color": "#3b82f6",
    "orientation": "any",
    "categories": ["productivity", "utilities", "games", "developer"],
    "lang": "en",
