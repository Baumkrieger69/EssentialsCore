    "protocol_handlers": [
        {
            "protocol": "minecraft",
            "url": "/#/connect?server=%s"
        }
    ],
    "file_handlers": [
        {
            "action": "/#/files",
            "accept": {
                "application/json": [".json", ".mcmeta"],
                "text/plain": [".txt", ".log", ".yml", ".yaml", ".properties"],
                "application/zip": [".zip", ".jar"]
            }
        }
    ],
    "share_target": {
        "action": "/#/share",
        "method": "POST",
        "enctype": "multipart/form-data",
        "params": {
            "title": "title",
            "text": "text",
            "url": "url",
            "files": [
                {
                    "name": "files",
                    "accept": ["text/plain", "application/json", "application/zip"]
                }
            ]
        }
    },
    "permissions": [
        "background-sync",
        "notifications",
        "persistent-storage"
    ],
    "related_applications": [
        {
            "platform": "play",
            "url": "https://play.google.com/store/apps/details?id=com.essentialscore.mobile",
            "id": "com.essentialscore.mobile"
        },
        {
            "platform": "itunes",
            "url": "https://apps.apple.com/app/essentialscore/id123456789",
            "id": "123456789"
        }
    ],
    "scope_extensions": [
        {
            "origin": "https://api.essentialscore.com"
        }
    ],
